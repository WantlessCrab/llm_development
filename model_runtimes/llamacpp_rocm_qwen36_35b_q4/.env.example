# llama.cpp ROCm Qwen3.6 35B runtime controls.

# Copy before first build/run: cp .env.example .env
# First build/launch target:
# - build pinned llama.cpp with ROCm/HIP
# - expose only the AMD RX 7900 XTX through Docker
# - serve one OpenAI-compatible endpoint on 127.0.0.1:8023
# - validate through /health, /v1/models, /v1/chat/completions, and local_llm UI chat

# -----------------------------------------------------------------------------
# Build/source controls
# -----------------------------------------------------------------------------

BASE_IMAGE=rocm/dev-ubuntu-24.04:7.1.1-complete
LLAMACPP_REPO=https://github.com/ggml-org/llama.cpp.git
LLAMACPP_REF=cfff1fc3003239cfe00aca031345107687d30d7b
AMDGPU_TARGETS=gfx1100
CMAKE_BUILD_TYPE=Release
LLAMA_CURL=ON

# -----------------------------------------------------------------------------
# Runtime identity
# -----------------------------------------------------------------------------

RUNTIME_ID=qwen36_35b_q4_llamacpp
HOST_PORT=8023

# -----------------------------------------------------------------------------
# Model/API contract
# -----------------------------------------------------------------------------

LLAMA_ARG_MODEL=/workspace/models/Qwen3.6-35B-A3B-UD-Q4_K_S.gguf
LLAMA_ARG_ALIAS=local-qwen36-35b-q4-llamacpp
LLAMA_ARG_HOST=0.0.0.0
LLAMA_ARG_PORT=8000

# -----------------------------------------------------------------------------
# ROCm/GPU contract
# -----------------------------------------------------------------------------

LLAMA_ARG_DEVICE=ROCm0
ROCR_VISIBLE_DEVICES=0
HIP_VISIBLE_DEVICES=0
PYTHONUNBUFFERED=1

# -----------------------------------------------------------------------------
# First-boot runtime limits
# -----------------------------------------------------------------------------

LLAMA_ARG_CTX_SIZE=4096
LLAMA_ARG_N_GPU_LAYERS=auto

# -----------------------------------------------------------------------------
# Mixture-of-Experts memory policy
# -----------------------------------------------------------------------------

LLAMA_ARG_CPU_MOE=false
LLAMA_ARG_N_CPU_MOE=0

# -----------------------------------------------------------------------------
# KV cache / attention / reasoning policy
# -----------------------------------------------------------------------------
# LLAMA_ARG_FLASH_ATTN=auto allows llama.cpp to choose flash attention support.
# LLAMA_ARG_REASONING=off is required for local_llm baseline proof because
# local_llm reads choices[0].message.content, not message.reasoning_content.

LLAMA_ARG_CACHE_TYPE_K=q4_0
LLAMA_ARG_CACHE_TYPE_V=q4_0
LLAMA_ARG_FLASH_ATTN=auto
LLAMA_ARG_REASONING=off

# -----------------------------------------------------------------------------
# Batching / CPU helper policy
# -----------------------------------------------------------------------------

LLAMA_ARG_BATCH_SIZE=512
LLAMA_ARG_UBATCH_SIZE=256
LLAMA_ARG_THREADS=8
LLAMA_ARG_THREADS_BATCH=16
LLAMA_ARG_N_PARALLEL=1