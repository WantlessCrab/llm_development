# vLLM ROCm install controls.
#
# IMPORTANT:
# localproject/py312base currently contains torch 2.6.0+rocm7.1.0.
# vLLM prebuilt ROCm wheels are currently published for rocm700 and rocm721.
# rocm721 targets ROCm 7.2.1 nightly wheels and may not match this base.
# Treat this as the installation candidate until post-install and runtime validation pass.
VLLM_INSTALL_SPEC=vllm
VLLM_ROCM_VARIANT=rocm721

# First tiny model for proving the endpoint.
VLLM_MODEL=Qwen/Qwen2.5-0.5B-Instruct
VLLM_SERVED_MODEL_NAME=local-small

# API/key contract expected by local_llm config.
VLLM_API_KEY=not-needed

# Conservative first boot settings.
VLLM_MAX_MODEL_LEN=4096
VLLM_GPU_MEMORY_UTILIZATION=0.70
VLLM_DTYPE=auto