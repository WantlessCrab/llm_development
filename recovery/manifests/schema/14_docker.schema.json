{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "14_docker.schema.json",
  "title": "Recovery Docker state report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.docker.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script",
        "docker_path"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "docker"
        },
        "script": {
          "type": "string"
        },
        "docker_path": {
          "type": "string"
        },
        "docker_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "compose_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "capture-info",
        "capture-daemon-config",
        "capture-systemd-overrides",
        "capture-contexts",
        "capture-containers",
        "capture-images",
        "capture-image-digests",
        "capture-networks",
        "capture-volumes",
        "capture-bind-mounts",
        "capture-compose-sources",
        "capture-compose-env",
        "capture-gpu-runtime-contracts",
        "export-selected-image",
        "volume-export-quiesced",
        "assert-postgres-volume-not-primary",
        "generate-compose-restore-plan"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "capture",
        "plan",
        "verify",
        "export",
        "guarded-export",
        "summary",
        null
      ]
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "docker": {
      "type": "object",
      "additionalProperties": true
    },
    "compose": {
      "type": "object",
      "additionalProperties": true
    },
    "containers": {
      "type": "object",
      "additionalProperties": true
    },
    "images": {
      "type": "object",
      "additionalProperties": true
    },
    "networks": {
      "type": "object",
      "additionalProperties": true
    },
    "volumes": {
      "type": "object",
      "additionalProperties": true
    },
    "mounts": {
      "type": "object",
      "additionalProperties": true
    },
    "gpu": {
      "type": "object",
      "additionalProperties": true
    },
    "exports": {
      "type": "object",
      "additionalProperties": true
    },
    "restore_plan": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    }
  }
}