{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "15_portainer.schema.json",
  "title": "Recovery Portainer workload report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.portainer.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script",
        "docker_path"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "portainer"
        },
        "script": {
          "type": "string"
        },
        "docker_path": {
          "type": "string"
        },
        "docker_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "capture-container",
        "capture-image",
        "capture-image-digest",
        "capture-volume",
        "capture-ports",
        "capture-mounts",
        "capture-networks",
        "export-staged-lts-image",
        "volume-export-quiesced",
        "generate-restore-plan",
        "generate-recreate-command",
        "validate-restore-prereqs",
        "gate-latest-not-authority"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "capture",
        "plan",
        "verify",
        "guarded-export",
        "summary",
        null
      ]
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "portainer": {
      "type": "object",
      "additionalProperties": true
    },
    "container": {
      "type": "object",
      "additionalProperties": true
    },
    "image": {
      "type": "object",
      "additionalProperties": true
    },
    "volume": {
      "type": "object",
      "additionalProperties": true
    },
    "ports": {
      "type": "object",
      "additionalProperties": true
    },
    "mounts": {
      "type": "object",
      "additionalProperties": true
    },
    "networks": {
      "type": "object",
      "additionalProperties": true
    },
    "exports": {
      "type": "object",
      "additionalProperties": true
    },
    "restore_plan": {
      "type": "object",
      "additionalProperties": true
    },
    "recreate_command": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        },
        "stdout_redacted": {
          "type": "boolean"
        },
        "redaction_kind": {
          "type": "string"
        }
      }
    }
  }
}