{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "13_desktop.schema.json",
  "title": "Recovery desktop settings report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.desktop.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "desktop"
        },
        "script": {
          "type": "string"
        },
        "dconf_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "dconf_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "xrandr_path": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "capture-session",
        "export-dconf",
        "load-dconf-preview",
        "load-dconf-guarded",
        "export-cinnamon-files",
        "restore-cinnamon-preview",
        "capture-monitor-layout",
        "capture-monitor-edid",
        "capture-audio-input",
        "capture-theme-icon-cursor",
        "capture-wallpaper",
        "capture-autostart",
        "validate-restore-context"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "capture",
        "preview",
        "restore",
        "verify",
        "summary",
        null
      ]
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": true
    },
    "dconf": {
      "type": "object",
      "additionalProperties": true
    },
    "files": {
      "type": "object",
      "additionalProperties": true
    },
    "monitor": {
      "type": "object",
      "additionalProperties": true
    },
    "edid": {
      "type": "object",
      "additionalProperties": true
    },
    "audio_input": {
      "type": "object",
      "additionalProperties": true
    },
    "themes": {
      "type": "object",
      "additionalProperties": true
    },
    "wallpaper": {
      "type": "object",
      "additionalProperties": true
    },
    "autostart": {
      "type": "object",
      "additionalProperties": true
    },
    "restore_plan": {
      "type": "object",
      "additionalProperties": true
    },
    "capture_session": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "subcommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "completed_count": {
          "type": "integer"
        },
        "failed_count": {
          "type": "integer"
        },
        "non_destructive": {
          "type": "boolean"
        },
        "partial_evidence_preserved": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    }
  }
}