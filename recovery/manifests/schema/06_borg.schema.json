{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "06_borg.schema.json",
  "title": "Recovery Borg report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.borg.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script",
        "borg_path"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "borg"
        },
        "script": {
          "type": "string"
        },
        "borg_path": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "assert-version",
        "init-repo",
        "export-key",
        "verify-key-export",
        "repo-info",
        "check",
        "list-archives",
        "mount-readonly",
        "extract-test-file",
        "restore-preview",
        "restore-selected",
        "capture-archive-inventory",
        "gate"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "repository": {
      "type": [
        "string",
        "null"
      ]
    },
    "archive": {
      "type": [
        "string",
        "null"
      ]
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "dry-run",
        "execute",
        "assert",
        "summary",
        null
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "borg": {
      "type": "object",
      "additionalProperties": true
    },
    "repository_info": {
      "type": "object",
      "additionalProperties": true
    },
    "archive_inventory": {
      "type": "object",
      "additionalProperties": true
    },
    "key_export": {
      "type": "object",
      "additionalProperties": true
    },
    "restore": {
      "type": "object",
      "additionalProperties": true
    },
    "mount": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    }
  }
}