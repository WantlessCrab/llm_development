{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "09_journalctl.schema.json",
  "title": "Recovery journalctl evidence report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.journalctl.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script",
        "journalctl_path",
        "systemctl_path"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "journalctl"
        },
        "script": {
          "type": "string"
        },
        "journalctl_path": {
          "type": "string"
        },
        "systemctl_path": {
          "type": "string"
        },
        "journalctl_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "systemd_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "capture-recovery-units",
        "capture-boot-warnings",
        "capture-kernel-storage-warnings",
        "capture-docker-libvirt-errors",
        "capture-timer-history",
        "export-json",
        "export-native",
        "list-boots",
        "capture-previous-boot",
        "capture-failure-context"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "evidence",
        "export",
        "summary",
        "assert",
        null
      ]
    },
    "exports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/export"
      }
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    },
    "export": {
      "type": "object",
      "required": [
        "label",
        "kind",
        "path",
        "bytes",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "line_count": {
          "type": "integer"
        },
        "returncode": {
          "type": "integer"
        }
      }
    }
  }
}