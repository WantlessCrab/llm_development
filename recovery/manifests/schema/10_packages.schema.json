{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "10_packages.schema.json",
  "title": "Recovery native package report",
  "type": "object",
  "required": [
    "schema",
    "tool",
    "command",
    "generated_at",
    "host",
    "project_root",
    "run_dir",
    "ok",
    "failures",
    "warnings"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "const": "recovery.packages.v1"
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "script"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "const": "packages"
        },
        "script": {
          "type": "string"
        },
        "apt_path": {
          "type": "string"
        },
        "dpkg_path": {
          "type": "string"
        },
        "apt_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "dpkg_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "command": {
      "type": "string",
      "enum": [
        "capture-os",
        "capture-sources",
        "capture-keyrings",
        "capture-preferences",
        "capture-policy",
        "capture-dpkg",
        "capture-manual-auto-holds",
        "capture-selections",
        "capture-critical",
        "build-local-deb-manifest",
        "verify-critical-debs",
        "restore-plan",
        "generate-reinstall-script"
      ]
    },
    "generated_at": {
      "type": "string"
    },
    "host": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "capture",
        "plan",
        "verify",
        "summary",
        null
      ]
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command_result"
      }
    },
    "os": {
      "type": "object",
      "additionalProperties": true
    },
    "packages": {
      "type": "object",
      "additionalProperties": true
    },
    "apt": {
      "type": "object",
      "additionalProperties": true
    },
    "dpkg": {
      "type": "object",
      "additionalProperties": true
    },
    "restore_plan": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "command_result": {
      "type": "object",
      "required": [
        "argv",
        "returncode"
      ],
      "additionalProperties": true,
      "properties": {
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "returncode": {
          "type": "integer"
        },
        "stdout_path": {
          "type": "string"
        },
        "stderr_path": {
          "type": "string"
        },
        "stderr": {
          "type": "string"
        }
      }
    }
  }
}