# data_stack/.env.example
#
# Copy to .env before first Phase 1.5 packet-native database run:
#   cp .env.example .env
#
# .env is local-only and must not be committed.
# Replace POSTGRES_PASSWORD with a local secret value.

POSTGRES_DB=llm_database
POSTGRES_USER=llm_database
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_ONLY
POSTGRES_HOST_PORT=8032

# Optional local timezone for container logs.
TZ=America/Denver