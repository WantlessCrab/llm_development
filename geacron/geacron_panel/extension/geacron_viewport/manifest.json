{
  "manifest_version": 3,
  "key": "",
  "name": "GeaCron Panel Viewport Adapter",
  "version": "1.2.0",
  "description": "Frames the native GeaCron map and provides panel controls for the dedicated GeaCron window.",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://geacron.com/*",
        "https://*.geacron.com/*",
        "http://geacron.com/*",
        "http://*.geacron.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": false
    }
  ]
}